# Deribit API (production for live recording; testnet for integration tests)
DERIBIT_API_KEY=
DERIBIT_API_SECRET=
DERIBIT_ENVIRONMENT=production

# Storage
ATLAS_DATA_PATH=./data

# Recording
ATLAS_CHANNELS=book,ticker,trades
ATLAS_INTERVAL=100ms
ATLAS_FUTURES_COUNT=3

# Logging
ATLAS_LOG_LEVEL=INFO
ATLAS_LOG_FORMAT=json
