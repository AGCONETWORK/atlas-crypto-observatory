# Deribit API (production for live recording; testnet for integration tests)
DERIBIT_API_KEY=your_api_key_here
DERIBIT_API_SECRET=your_api_secret_here
DERIBIT_ENVIRONMENT=production

# Storage
ATLAS_DATA_PATH=./data

# Recording
ATLAS_CHANNELS=book,ticker,trades
ATLAS_INTERVAL=100ms
ATLAS_FUTURES_COUNT=3

# Logging
ATLAS_LOG_LEVEL=INFO
ATLAS_LOG_FORMAT=json

# Deribit connection
ATLAS_DERIBIT_HEARTBEAT_INTERVAL=30
ATLAS_DERIBIT_RECONNECT_BASE_DELAY=1.0
ATLAS_DERIBIT_RECONNECT_MAX_DELAY=60.0

# Hardening (v0.6.0)
ATLAS_STORAGE_FLUSH_EVERY=500
ATLAS_HEALTH_STALE_THRESHOLD_SECONDS=120.0
